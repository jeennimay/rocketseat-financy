JWT_SECRET=                        # segredo para assinar tokens JWT (obrigatório)

DATABASE_URL="file:./prisma/dev.db" # caminho do banco SQLite

PORT=4000                           # porta do servidor (opcional, padrão 4000)

# Origem(ns) permitida(s) pelo CORS. Em produção use domínios reais.
# Para múltiplas origens, separe por vírgula (sem espaços):
# CORS_ORIGIN=https://app.exemplo.com,https://staging.exemplo.com
# Atenção: credentials:true exige origem explícita (não use wildcard *).
CORS_ORIGIN=http://localhost:5173
